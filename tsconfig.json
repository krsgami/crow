{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    // "paths": {
    //   "@/*": [
    //     "./src/*"
    //   ]
    // }
  },
  "include": [
    "src/**/*",
    "src/events/guild/giveExp.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}